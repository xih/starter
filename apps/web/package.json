{
  "name": "@starter/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "SKIP_ENV_VALIDATION=1 next build",
    "build:public-storybook": "rm -rf public/storybook storybook-static && SKIP_ENV_VALIDATION=1 storybook build && mkdir -p public && cp -R storybook-static public/storybook",
    "build:vercel": "corepack pnpm --filter @starter/tokens build && corepack pnpm build:public-storybook && SKIP_ENV_VALIDATION=1 next build",
    "check": "corepack pnpm lint && corepack pnpm typecheck",
    "dev": "infisical run --env=${INFISICAL_ENV:-dev} -- next dev --turbo",
    "dev:local": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "SKIP_ENV_VALIDATION=1 eslint . --cache",
    "lint:fix": "SKIP_ENV_VALIDATION=1 eslint . --cache --fix",
    "preview": "SKIP_ENV_VALIDATION=1 next build && next start",
    "prebuild": "corepack pnpm --filter @starter/tokens build",
    "prebuild-storybook": "corepack pnpm --filter @starter/tokens build",
    "predev": "corepack pnpm --filter @starter/tokens build",
    "prestorybook": "corepack pnpm --filter @starter/tokens build",
    "start": "next start",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "storybook": "SKIP_ENV_VALIDATION=1 storybook dev -p 6006",
    "build-storybook": "SKIP_ENV_VALIDATION=1 storybook build"
  },
