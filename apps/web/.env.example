# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Next Auth
# You can generate a new secret on the command line with:
# npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET=""

# Next Auth Discord Provider
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# LiveKit token endpoint
LIVEKIT_URL=""
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""
LIVEKIT_AGENT_NAME=""
NEXT_PUBLIC_LIVEKIT_AGENT_NAME=""
NEXT_PUBLIC_LIVEKIT_PROJECT_ENV="development"

# Comma-separated browser origins allowed to call LiveKit token endpoints.
# Localhost defaults are applied in development only when this is unset.
LIVEKIT_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:6006"

# Required in production before /api/livekit/token will issue LiveKit grants.
# Send as `Authorization: Bearer <secret>` or `X-LiveKit-Token-Auth: <secret>`.
LIVEKIT_TOKEN_AUTH_SECRET=""

# Required in production for persona mutation endpoints such as create/update,
# YouTube ingest, memory writes, and Cartesia voice cloning.
PERSONA_ADMIN_SECRET=""
PERSONA_CARTESIA_VOICE_ID=""
PERSONA_STEVE_JOBS_CARTESIA_VOICE_ID=""
PERSONA_WIFE_E2E_CARTESIA_VOICE_ID=""

# Required in production for persona transcript and memory embeddings.
# Development/test falls back to labeled local hash embeddings when unset.
OPENAI_API_KEY=""

# Required for public /api/livekit/guest-session requests.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
LIVEKIT_GUEST_RATE_LIMIT_SALT=""
LIVEKIT_GUEST_CLEANUP_ENABLED="false"

# Required only when guest-session delayed cleanup is enabled.
QSTASH_URL=""
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# Optional persona e2e test harness values.
# Run with: make persona-e2e
PERSONA_E2E_BASE_URL="http://localhost:3000"
PERSONA_E2E_PERSONA_ID="wife-e2e"
PERSONA_E2E_DISPLAY_NAME="Wife E2E"
PERSONA_E2E_USER_ID="persona-e2e-user"
PERSONA_E2E_YOUTUBE_URL="https://www.youtube.com/watch?v=sCRpxq1XRUI"
PERSONA_E2E_TRANSCRIPT=""
PERSONA_E2E_MEMORY_TEXT="Dennis wants this persona to remember that short answers are best."
PERSONA_E2E_CARTESIA_VOICE_IDS=""
PERSONA_E2E_AGENT_READ_SECRET=""
PERSONA_E2E_TOKEN_AUTH=""
PERSONA_E2E_AGENT_NAME="dennis-portfolio-agent"
PERSONA_E2E_RUN_CLONE="0"
PERSONA_E2E_CLONE_CLIP_PATH=""
PERSONA_E2E_CLONE_CLIP_TYPE="audio/wav"
PERSONA_E2E_VOICE_CONSENT_ARTIFACT_URL=""
PERSONA_E2E_RUN_LIVEKIT_TOKEN="0"
